[% SET footerjs = 1 %]
[% INCLUDE 'doc-head-open.inc' %]
<title>Koha: <% project %> - <% action | capitalize %></title>
[% INCLUDE 'doc-head-close.inc' %]
</head>

<body>
    [% WRAPPER 'header.inc' %]
        <% IF action == 'admin' %>
            [% INCLUDE 'prefs-admin-search.inc' %]
        <% END %>
    [% END %]

    <nav aria-label="breadcrumb" id="breadcrumbs">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/mainpage.pl">Home</a></li>
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/plugins/plugins-home.pl">Plugins</a></li>
            <li class="breadcrumb-item"><a href="#"><% project %></a></li>
            <li class="breadcrumb-item active"><% action | capitalize %></li>
        </ol>
    </nav>

    <div class="main container-fluid">
        <div class="row">
            <div class="col-sm-12">Hello, <% project %>!</div>
        </div>
    </div>

[% INCLUDE 'intranet-bottom.inc' %]
