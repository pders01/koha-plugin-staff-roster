    "/rosters/{roster_id}/week": {
        "get": {
            "operationId": "getRosterWeek",
            "parameters": [
                {
                    "description": "roster_id identifier",
                    "in": "path",
                    "name": "roster_id",
                    "required": true,
                    "type": "integer"
                },
                {
                    "description": "Week start date (YYYY-MM-DD, defaults to current week's Monday)",
                    "in": "query",
                    "name": "start",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                    "required": false,
                    "type": "string"
                }
            ],
            "produces": [
                "application/json"
            ],
            "responses": {
                "200": {
                    "description": "Slots, assignments, and exceptions for a roster week",
                    "schema": {
                        "type": "object"
                    }
                },
                "403": {
                    "description": "Access forbidden",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "404": {
                    "description": "Not found",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "500": {
                    "description": "Internal error",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                }
            },
            "summary": "Slots, assignments, and exceptions for a roster week",
            "tags": [
                "StaffRoster"
            ],
            "x-koha-authorization": {
                "permissions": {
                    "plugins": "staffroster_view"
                }
            },
            "x-mojo-to": "Xyz::Paulderscheid::StaffRoster::RosterController#get_week"
        }
    },
    "/staff/available": {
        "get": {
            "operationId": "listAvailableStaff",
            "parameters": [
                {
                    "description": "Assignment date",
                    "in": "query",
                    "name": "date",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                    "required": true,
                    "type": "string"
                },
                {
                    "description": "Filter by slot (excludes overlapping assignments)",
                    "in": "query",
                    "name": "slot_id",
                    "required": false,
                    "type": "integer"
                },
                {
                    "description": "Filter by branchcode",
                    "in": "query",
                    "name": "branch",
                    "required": false,
                    "type": "string"
                },
                {
                    "description": "Search firstname/surname/cardnumber",
                    "in": "query",
                    "name": "q",
                    "required": false,
                    "type": "string"
                }
            ],
            "produces": [
                "application/json"
            ],
            "responses": {
                "200": {
                    "description": "List available staff for a slot/date",
                    "schema": {
                        "items": {
                            "type": "object"
                        },
                        "type": "array"
                    }
                },
                "403": {
                    "description": "Access forbidden",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "500": {
                    "description": "Internal error",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                }
            },
            "summary": "List available staff for a slot/date",
            "tags": [
                "StaffRoster"
            ],
            "x-koha-authorization": {
                "permissions": {
                    "plugins": "staffroster_assign"
                }
            },
            "x-mojo-to": "Xyz::Paulderscheid::StaffRoster::StaffController#available"
        }
