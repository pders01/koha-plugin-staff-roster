{
    "/assignments": {
        "post": {
            "consumes": [
                "application/json"
            ],
            "operationId": "createAssignment",
            "parameters": [
                {
                    "in": "body",
                    "name": "body",
                    "required": true,
                    "schema": {
                        "properties": {
                            "assignment_date": {
                                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                                "type": "string"
                            },
                            "borrowernumber": {
                                "type": "integer"
                            },
                            "notes": {
                                "type": "string"
                            },
                            "slot_id": {
                                "type": "integer"
                            },
                            "status": {
                                "enum": [
                                    "scheduled",
                                    "confirmed",
                                    "completed",
                                    "cancelled",
                                    "no_show"
                                ],
                                "type": "string"
                            }
                        },
                        "required": [
                            "slot_id",
                            "borrowernumber",
                            "assignment_date"
                        ],
                        "type": "object"
                    }
                }
            ],
            "produces": [
                "application/json"
            ],
            "responses": {
                "201": {
                    "description": "Assign staff to a slot on a date",
                    "schema": {
                        "type": "object"
                    }
                },
                "400": {
                    "description": "Bad request",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "403": {
                    "description": "Access forbidden",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "409": {
                    "description": "Conflict (slot full, overlap, calendar closed)",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "500": {
                    "description": "Internal error",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                }
            },
            "summary": "Assign staff to a slot on a date",
            "tags": [
                "StaffRoster"
            ],
            "x-koha-authorization": {
                "permissions": {
                    "plugins": "staffroster_assign"
                }
            },
            "x-mojo-to": "Xyz::Paulderscheid::StaffRoster::AssignmentController#create"
        }
    },
    "/assignments/bulk": {
        "post": {
            "consumes": [
                "application/json"
            ],
            "operationId": "bulkAssignments",
            "parameters": [
                {
                    "in": "body",
                    "name": "body",
                    "required": true,
                    "schema": {
                        "properties": {
                            "ids": {
                                "items": {
                                    "type": "integer"
                                },
                                "minItems": 1,
                                "type": "array"
                            },
                            "op": {
                                "enum": [
                                    "move",
                                    "clear"
                                ],
                                "type": "string"
                            },
                            "target": {
                                "properties": {
                                    "assignment_date": {
                                        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                                        "type": "string"
                                    },
                                    "borrowernumber": {
                                        "type": "integer"
                                    },
                                    "slot_id": {
                                        "type": "integer"
                                    }
                                },
                                "type": "object"
                            }
                        },
                        "required": [
                            "op",
                            "ids"
                        ],
                        "type": "object"
                    }
                }
            ],
            "produces": [
                "application/json"
            ],
            "responses": {
                "201": {
                    "description": "Bulk assignment ops (move/reassign/clear)",
                    "schema": {
                        "type": "object"
                    }
                },
                "400": {
                    "description": "Bad request",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "403": {
                    "description": "Access forbidden",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "409": {
                    "description": "Conflict (slot full, overlap, calendar closed)",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                },
                "500": {
                    "description": "Internal error",
                    "schema": {
                        "properties": {
                            "error": {
                                "description": "Error message",
                                "type": "string"
                            }
                        },
                        "type": "object"
                    }
                }
            },
            "summary": "Bulk assignment ops (move/reassign/clear)",
            "tags": [
                "StaffRoster"
            ],
            "x-koha-authorization": {
                "permissions": {
                    "plugins": "staffroster_assign"
                }
            },
            "x-mojo-to": "Xyz::Paulderscheid::StaffRoster::AssignmentController#bulk"
        }
    },
